	"item": [
		{
			"name": "Autocomplete",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Response contains suggestions array\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property('suggestions');",
							"    pm.expect(jsonData.suggestions).to.be.an('array');",
							"});",
							"",
							"pm.test(\"Response contains count integer\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property('count');",
							"    pm.expect(jsonData.count).to.be.a('number');",
							"});",
							"",
							"pm.test(\"Suggestions have required fields\", function () {",
							"    var jsonData = pm.response.json();",
							"    if (jsonData.suggestions.length > 0) {",
							"        var suggestion = jsonData.suggestions[0];",
							"        pm.expect(suggestion).to.have.property('place_id');",
							"        pm.expect(suggestion).to.have.property('description');",
							"        pm.expect(suggestion).to.have.property('main_text');",
							"        pm.expect(suggestion).to.have.property('secondary_text');",
							"    }",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [
						{
							"key": "token",
							"value": "{{token}}",
							"type": "string"
						}
					]
				},
				"method": "GET",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{base_url}}/api/locations/autocomplete/?q=westlands",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"locations",
						"autocomplete",
						""
					],
					"query": [
						{
							"key": "q",
							"value": "westlands",
							"description": "Search query for location autocomplete"
						}
					]
				},
				"description": "Get autocomplete suggestions for location search. Tests Google Places Autocomplete API integration."
			},
			"response": []
		},
		{
			"name": "Reverse Geocode",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Response contains formatted_address\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property('formatted_address');",
							"    pm.expect(jsonData.formatted_address).to.be.a('string');",
							"    pm.expect(jsonData.formatted_address).to.not.be.empty;",
							"});",
							"",
							"pm.test(\"Response contains place_id\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property('place_id');",
							"});",
							"",
							"pm.test(\"Response contains location coordinates\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property('location');",
							"    pm.expect(jsonData.location).to.have.property('lat');",
							"    pm.expect(jsonData.location).to.have.property('lng');",
							"});",
							"",
							"pm.test(\"Response contains address_components\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property('address_components');",
							"    pm.expect(jsonData.address_components).to.be.an('array');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [
